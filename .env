# 🔑 API Keys
# Add at least one API key below

# Gemini (Google)
GEMINI_API_KEY=enter-your-api-key-here

# Claude (Anthropic)
ANTHROPIC_API_KEY=enter-your-api-key-here

# GPT (OpenAI)
OPENAI_API_KEY=enter-your-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# 🎮 Model Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Narrator Model (the main AI game master)
# Options: "claude-sonnet-4-6" | "gemini-3.1-pro-preview" | "gpt-5.4"
NARRATOR_MODEL=gemini-3.1-pro-preview

# Image Generation Model
# Options: "imagen-4.0-generate-001" | "gpt-image-1.5"
IMAGE_MODEL=gpt-image-1.5

# ─────────────────────────────────────────────────────────────────────────────
# 📝 Notes
# ─────────────────────────────────────────────────────────────────────────────
#
# Model Requirements:
# - Claude models need ANTHROPIC_API_KEY
# - Gemini models need GEMINI_API_KEY
# - GPT models need OPENAI_API_KEY
# - Image models:
#     - Imagen → GEMINI_API_KEY
#     - GPT Image → OPENAI_API_KEY
#
# Quick Configurations:
#
# Claude narration (any image):
#   NARRATOR_MODEL=claude-sonnet-4-6
#   IMAGE_MODEL=imagen-4.0-generate-001 or gpt-image-1.5
#   Requires: ANTHROPIC_API_KEY + image API key
#
# Gemini narration (any image):
#   NARRATOR_MODEL=gemini-3.1-pro-preview
#   IMAGE_MODEL=imagen-4.0-generate-001 or gpt-image-1.5
#   Requires: GEMINI_API_KEY + image API key
#
# GPT narration (any image):
#   NARRATOR_MODEL=gpt-5.4
#   IMAGE_MODEL=imagen-4.0-generate-001 or gpt-image-1.5
#   Requires: OPENAI_API_KEY + image API key
